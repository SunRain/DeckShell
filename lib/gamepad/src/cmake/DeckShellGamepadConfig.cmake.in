@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

set(DECKSHELL_GAMEPAD_ENABLE_LOGIND @DECKSHELL_GAMEPAD_ENABLE_LOGIND@)

find_dependency(Qt6 6.8 REQUIRED COMPONENTS Core)
if(DECKSHELL_GAMEPAD_ENABLE_LOGIND)
    find_dependency(Qt6 6.8 REQUIRED COMPONENTS DBus)
endif()
find_dependency(PkgConfig REQUIRED)
pkg_check_modules(UDEV REQUIRED IMPORTED_TARGET libudev)

include("${CMAKE_CURRENT_LIST_DIR}/DeckShellGamepadTargets.cmake")

check_required_components(DeckShellGamepad)
